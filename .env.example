# Copy this file to .env.local and fill in real values. `.env.local` is
# gitignored via the `*.local` pattern; never commit real secrets here.

# Runtime (baked into the client bundle at build time)
VITE_SENTRY_DSN=
VITE_POSTHOG_KEY=
VITE_POSTHOG_HOST=https://us.i.posthog.com

# Build-time only (used by the Sentry Vite plugin to upload source maps).
# Leave blank in local dev to skip upload. The plugin only runs when all
# three are set.
SENTRY_AUTH_TOKEN=
SENTRY_ORG=
SENTRY_PROJECT=
